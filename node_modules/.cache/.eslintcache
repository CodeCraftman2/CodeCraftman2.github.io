ages":"98","suppressedMessages":"99","errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":3,"source":"100","usedDeprecatedRules":"51"},{"filePath":"101","messages":"102","suppressedMessages":"103","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"104","messages":"105","suppressedMessages":"106","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"107","messages":"108","suppressedMessages":"109","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"110","messages":"111","suppressedMessages":"112","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"113","messages":"114","suppressedMessages":"115","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},{"filePath":"116","messages":"117","suppressedMessages":"118","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"119","usedDeprecatedRules":"51"},{"filePath":"120","messages":"121","suppressedMessages":"122","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"51"},"D:\\SoA Exam\\Webstrome\\src\\index.js",[],[],[],"D:\\SoA Exam\\Webstrome\\src\\App.js",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\home\\Home.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\services\\Services.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\header\\Header.jsx",["123"],[],"import React, {useState} from \"react\";\r\nimport './header.css';\r\nimport { HiOutlineHome, HiOutlineUser, HiOutlineBadgeCheck, HiOutlineClipboardList, HiOutlinePhotograph, HiOutlineMail, HiX, HiOutlineMenu,HiOutlineViewGrid } from \"react-icons/hi\";\r\n\r\n\r\nconst Header = () => {\r\n    window.addEventListener(\"scroll\", function () {\r\n        const header = document.querySelector(\".header\");\r\n        if(this.scrollY >= 80) header.classList.add(\"scroll-header\");\r\n        else header.classList.remove(\"scroll-header\");\r\n    });\r\n\r\n    const[Toggle, showMenu] = useState(false);\r\n    const[activeNav, setActiveNav] = useState(\"#home\");\r\n\r\n    return(\r\n        <header className=\"header\">\r\n            <nav className=\"nav container\">\r\n                <a href=\"index.html\" className=\"nav__logo\">CodeCraftman2</a>\r\n                <div className={Toggle ? \"nav__menu show-menu\" : \"nav__menu\"}>\r\n                    <ul className=\"nav__list grid\">\r\n                        <li className=\"nav__item\">\r\n                            <a href=\"#home\" onClick={() => setActiveNav(\"#home\")}\r\n                               className={activeNav === \"#home\" ? \"nav__link active-link\" : \"nav__link\"}>\r\n                                <HiOutlineHome className=\"nav__icon\"/>Home\r\n                            </a>\r\n                        </li>\r\n                        <li className=\"nav__item\">\r\n                            <a href=\"#about\" onClick={() => setActiveNav(\"#about\")}\r\n                               className={activeNav === \"#about\" ? \"nav__link active-link\" : \"nav__link\"}>\r\n                                <HiOutlineUser className=\"nav__icon\"/>About\r\n                            </a>\r\n                        </li>\r\n                        <li className=\"nav__item\">\r\n                            <a href=\"#skills\" onClick={() => setActiveNav(\"#skills\")}\r\n                               className={activeNav === \"#skills\" ? \"nav__link active-link\" : \"nav__link\"}>\r\n                                <HiOutlineBadgeCheck className=\"nav__icon\"/>Skills\r\n                            </a>\r\n                        </li>\r\n                        <li className=\"nav__item\">\r\n                            <a href=\"#services\" onClick={() => setActiveNav(\"#services\")}\r\n                               className={activeNav === \"#services\" ? \"nav__link active-link\" : \"nav__link\"}>\r\n                                <HiOutlineClipboardList className=\"nav__icon\"/>Services\r\n                            </a>\r\n                        </li>\r\n                        <li className=\"nav__item\">\r\n                            <a href=\"#portfolio\" onClick={() => setActiveNav(\"#portfolio\")}\r\n                               className={activeNav === \"#portfolio\" ? \"nav__link active-link\" : \"nav__link\"}>\r\n                                <HiOutlinePhotograph className=\"nav__icon\"/>Projects\r\n                            </a>\r\n                        </li>\r\n                        <li className=\"nav__item\">\r\n                            <a href=\"#contact\" onClick={() => setActiveNav(\"#contact\")}\r\n                               className={activeNav === \"#contact\" ? \"nav__link active-link\" : \"nav__link\"}>\r\n                                <HiOutlineMail className=\"nav__icon\"/>Contact\r\n                            </a>\r\n                        </li>\r\n                    </ul>\r\n                    <HiX className=\"nav__close\" onClick={() => showMenu(!Toggle)} />\r\n                </div>\r\n                <div className=\"nav__toggle\" onClick={() => showMenu(!Toggle)}>\r\n                    <HiOutlineViewGrid />\r\n                </div>\r\n            </nav>\r\n        </header>\r\n    )\r\n}\r\n\r\nexport default Header;","D:\\SoA Exam\\Webstrome\\src\\components\\about\\About.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\qualification\\Qualification.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\skills\\Skills.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\footer\\Footer.jsx",["124","125","126","127"],[],"import React from 'react';\r\nimport \"./footer.css\";\r\nimport {FiTwitter, FiGithub, FiLinkedin, FiInstagram} from 'react-icons/fi';\r\n\r\nconst Footer = () => {\r\n  return (\r\n    <footer className=\"footer\">\r\n        <div className=\"footer__container container\">\r\n            <h1 className=\"footer__title\">CodeCraftman2</h1>\r\n            <ul className=\"footer__list\">\r\n                <li>\r\n                    <a href=\"#about\" className=\"footer__link\">About</a>\r\n                </li>\r\n                <li>\r\n                    <a href=\"#portfolio\" className=\"footer__link\">Projects</a>\r\n                </li>\r\n                <li>\r\n                    <a href=\"#testimonials\" className=\"footer__link\">Testimonials</a>\r\n                </li>\r\n            </ul>\r\n            <div className=\"footer__social\">\r\n                <a href=\"https://www.instagram.com/ramramsa.sa/?hl=en\" className=\"home__social-icon\" target=\"_blank\">\r\n                    <FiInstagram />\r\n                </a>\r\n                <a href=\"https://github.com/CodeCraftman2\" className=\"home__social-icon\" target=\"_blank\">\r\n                    <FiGithub />\r\n                </a>\r\n                <a href=\"https://www.linkedin.com/in/yagya-saini-05739a267/\" className=\"home__social-icon\" target=\"_blank\">\r\n                    <FiLinkedin />\r\n                </a>    \r\n            </div>\r\n            <span className=\"footer__copy\"></span>\r\n        </div>\r\n    </footer>\r\n  );\r\n}\r\n\r\nexport default Footer;","D:\\SoA Exam\\Webstrome\\src\\components\\testimonials\\Testimonials.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\scrollup\\ScrollUp.jsx",["128"],[],"import React from 'react';\r\nimport './scrollup.css';\r\nimport { HiOutlineArrowSmUp } from \"react-icons/hi\";\r\n\r\nconst ScrollUp = () => {\r\n    window.addEventListener(\"scroll\", function () {\r\n        const scrollUp = document.querySelector(\".scrollup\");\r\n        if(this.scrollY >= 560) scrollUp.classList.add(\"show-scroll\");\r\n        else scrollUp.classList.remove(\"show-scroll\");\r\n    });\r\n  \r\n    return (\r\n    <a href=\"#\" className=\"scrollup\"><HiOutlineArrowSmUp className=\"scrollup__icon\"/></a>\r\n  );\r\n}\r\n\r\nexport default ScrollUp;","D:\\SoA Exam\\Webstrome\\src\\components\\projects\\Portfolio.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\contact\\Contact.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\home\\Scroll.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\home\\Data.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\home\\Social.jsx",["129","130","131","132"],[],"import React from \"react\";\r\nimport {FiTwitter, FiGithub, FiLinkedin, FiInstagram} from \"react-icons/fi\";\r\n\r\nconst Social = () => {\r\n    return (\r\n        <div className=\"home__social\">\r\n            <a href=\"https://www.instagram.com/ramramsa.sa/?hl=en\" className=\"home__social-icon\" target=\"_blank\">\r\n                <FiInstagram />\r\n            </a>\r\n            <a href=\"https://github.com/CodeCraftman2\" className=\"home__social-icon\" target=\"_blank\">\r\n                <FiGithub />\r\n            </a>\r\n            <a href=\"https://www.linkedin.com/in/yagya-saini-05739a267/\" className=\"home__social-icon\" target=\"_blank\">\r\n                <FiLinkedin />\r\n            </a>\r\n        </div> \r\n    ); \r\n}\r\n\r\nexport default Social;","D:\\SoA Exam\\Webstrome\\src\\components\\about\\Info.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\skills\\Backend.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\skills\\Frontend.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\testimonials\\Data.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\projects\\Projects.jsx",[],[],"D:\\SoA Exam\\Webstrome\\src\\components\\projects\\ProjectItems.jsx",["133"],[],"import React from 'react';\r\nimport { HiOutlineArrowSmRight } from \"react-icons/hi\";\r\n\r\nconst ProjectItems = ({item}) => {\r\n  return (\r\n        <div className=\"project__card\" key={item.id}>\r\n            <img className=\"project__img\" src={item.image} alt=\"\" />\r\n            <h3 className=\"project__title\">{item.title}</h3>\r\n            <a href=\"#\" className=\"project__button\">\r\n                Demo <HiOutlineArrowSmRight className=\"project__button-icon\" />\r\n            </a>\r\n        </div>\r\n    );\r\n}\r\n\r\nexport default ProjectItems;","D:\\SoA Exam\\Webstrome\\src\\components\\projects\\Data.jsx",[],[],{"ruleId":"134","severity":1,"message":"135","line":3,"column":126,"nodeType":"136","messageId":"137","endLine":3,"endColumn":139},{"ruleId":"134","severity":1,"message":"138","line":3,"column":9,"nodeType":"136","messageId":"137","endLine":3,"endColumn":18},{"ruleId":"139","severity":1,"message":"140","line":22,"column":17,"nodeType":"141","messageId":"142","endLine":22,"endColumn":118,"fix":"143"},{"ruleId":"139","severity":1,"message":"140","line":25,"column":17,"nodeType":"141","messageId":"142","endLine":25,"endColumn":106,"fix":"144"},{"ruleId":"139","severity":1,"message":"140","line":28,"column":17,"nodeType":"141","messageId":"142","endLine":28,"endColumn":124,"fix":"145"},{"ruleId":"146","severity":1,"message":"147","line":13,"column":5,"nodeType":"141","endLine":13,"endColumn":38},{"ruleId":"134","severity":1,"message":"138","line":2,"column":9,"nodeType":"136","messageId":"137","endLine":2,"endColumn":18},{"ruleId":"139","severity":1,"message":"140","line":7,"column":13,"nodeType":"141","messageId":"142","endLine":7,"endColumn":114,"fix":"148"},{"ruleId":"139","severity":1,"message":"140","line":10,"column":13,"nodeType":"141","messageId":"142","endLine":10,"endColumn":102,"fix":"149"},{"ruleId":"139","severity":1,"message":"140","line":13,"column":13,"nodeType":"141","messageId":"142","endLine":13,"endColumn":120,"fix":"150"},{"ruleId":"146","severity":1,"message